# ----------------------------------------------------------------------------
# ShareLynk public website (Next.js) — environment
#
# This site talks to your EXISTING FastAPI backend (sharelynk/backend), which
# runs on http://localhost:8000. No database or secrets live here — the backend
# owns those (its .env has DATABASE_URL + JWT_SECRET).
# ----------------------------------------------------------------------------

# Browser /api/* requests are proxied here (see next.config.mjs).
API_PROXY_TARGET=http://localhost:8000

# Server-side (SSR/ISR) fetches of the download catalog.
API_INTERNAL_URL=http://localhost:8000

# Public site URL (used for canonical/OG metadata).
NEXT_PUBLIC_SITE_URL=http://localhost:3000
